// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ContactForm {
  id         String   @id @default(cuid())
  type       String
  prenom     String
  nom        String
  email      String
  telephone  String?
  entreprise String?
  siret      String?
  secteur    String?
  taille     String?
  urgence    String?
  message    String
  createdAt  DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @unique @default(uuid())
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Estimation réalisée via le tunnel /estimation.
// Anonyme par défaut : email, téléphone, entreprise et consentement
// uniquement si le visiteur demande à être recontacté. Aucune IP ni
// donnée identifiante sinon.
model Estimate {
  id          String          @id @default(cuid())
  sessionId   String
  answers     Json
  services    String[]
  monthlyMin  Int?
  monthlyMax  Int?
  oneShotMin  Int?
  oneShotMax  Int?
  breakdown   Json
  aiModifiers Json?
  aiAnalyzed  Boolean         @default(false)
  email       String?
  prenom      String?
  nom         String?
  telephone   String?
  entreprise  String?
  consentAt   DateTime?
  status      String          @default("complete")
  createdAt   DateTime        @default(now())
  events      EstimateEvent[]

  @@index([sessionId])
  @@index([createdAt])
}

// Audit SEO gratuit lancé depuis /audit-seo. Identité captée au Gate (en amont),
// analyse mécanique + synthèse IA. Un enregistrement = une Cible = un Rapport.
model SeoAudit {
  id          String    @id @default(cuid())
  // Lead (identité captée au Gate)
  prenom      String
  nom         String
  email       String
  entreprise  String
  telephone   String?
  consentAt   DateTime?
  // Cible
  url         String
  domain      String
  // Résultat mécanique
  scoreGlobal Int?
  sousScores  Json?
  findings    Json?
  pagespeed   Json?
  aiSummary   String?
  // pending → done → lead ; failed en cas d'échec d'analyse
  status      String    @default("pending")
  ipHash      String?
  createdAt   DateTime  @default(now())

  @@index([email])
  @@index([domain])
  @@index([createdAt])
}

// Étape franchie dans le tunnel, rattachée à une session éphémère.
model EstimateEvent {
  id         String    @id @default(cuid())
  sessionId  String
  step       String
  estimateId String?
  estimate   Estimate? @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model AuditOrder {
  id                    String    @id @default(cuid())
  prenom                String
  nom                   String
  email                 String
  entreprise            String
  tva                   String?
  url                   String
  seoAuditId            String?
  stripeSessionId       String?
  stripePaymentIntentId String?
  amountEur             Int
  status                String    @default("pending")
  cgvAcceptedAt         DateTime
  createdAt             DateTime  @default(now())
  paidAt                DateTime?
  deliveredAt           DateTime?

  @@index([email])
  @@index([status])
  @@index([createdAt])
}
