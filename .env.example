# Base de données
DATABASE_URL=postgresql://trinexta:dev_password@localhost:5432/trinexta

# URL publique du site (CRITIQUE pour les balises OG et les URLs absolues)
# local   : http://localhost:3000
# staging : https://staging.trinexta.fr
# prod    : https://trinexta.fr
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_STUDIO_DATASET=production
SANITY_API_TOKEN=
SANITY_WEBHOOK_SECRET="votre_secret_genere_depuis_sanity"

# Azure (envoi d'emails via Microsoft Graph)
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_FROM_EMAIL=contact@trinexta.com
SUPPORT_EMAIL="support@trinexta.fr"

# Google Places API (carte d'intervention)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Google Tag Manager (Analytics & RGPD)
NEXT_PUBLIC_GTM_ID=

# Intelligence Artificielle (outils de dev et workflows)
ANTHROPIC_API_KEY=

# Tunnel d'estimation
# Lien Microsoft Bookings pour le CTA "Prendre rendez-vous" (laisser vide tant que non fourni)
NEXT_PUBLIC_BOOKINGS_URL=

# Audit SEO (/audit-seo)
# Clé Google PageSpeed Insights pour l'axe Performance. Sans clé, l'appel reste
# possible mais fortement limité : l'axe Performance sera souvent "non mesuré".
PAGESPEED_API_KEY=
# Modèles de la Synthèse IA (optionnels, valeurs par défaut ci-dessous).
# La synthèse réutilise ANTHROPIC_API_KEY. Sans clé, l'audit aboutit sans narratif.
# AUDIT_SEO_AI_MODEL=claude-sonnet-5
# AUDIT_SEO_AI_FALLBACK_MODEL=claude-haiku-4-5
