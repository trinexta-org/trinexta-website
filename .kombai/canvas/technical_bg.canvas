      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700;1,900&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --primary: #0a233e;\n    --secondary: #5c92b8;\n    --font-serif: 'Playfair Display', serif;\n    --font-sans: 'Geist', sans-serif;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    font-family: var(--font-sans);\n    background-color: var(--primary);\n    color: white;\n  }\n\n  .font-serif { font-family: var(--font-serif); }\n  .font-sans { font-family: var(--font-sans); }\n\n  /* Background Animations */\n  @keyframes dash {\n    to { stroke-dashoffset: 0; }\n  }\n\n  @keyframes drift-slow {\n    from { transform: translate(-2%, -2%) scale(1); }\n    to { transform: translate(2%, 2%) scale(1.05); }\n  }\n\n  @keyframes glow-pulse {\n    0%, 100% { opacity: 0.1; transform: scale(1); }\n    50% { opacity: 0.2; transform: scale(1.1); }\n  }\n\n  @keyframes fade-in {\n    from { opacity: 0; }\n    to { opacity: 1; }\n  }\n\n  @keyframes fade-in-up {\n    from { opacity: 0; transform: translateY(20px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n\n  .animate-fade-in {\n    animation: fade-in 1s ease-out forwards;\n  }\n\n  .animate-fade-in-up {\n    animation: fade-in-up 1s ease-out forwards;\n  }\n\n  /* Component: AnimatedTechnicalBackground */\n  .tech-bg {\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    overflow: hidden;\n    z-index: 0;\n  }\n\n  .tech-bg-hero {\n    mask-image: radial-gradient(circle at center, black 20%, transparent 90%);\n  }\n\n  .tech-bg-section {\n    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);\n  }\n\n  .tech-bg-cta {\n    mask-image: radial-gradient(circle at center, black 40%, transparent 95%);\n  }\n\n  .tech-line {\n    fill: none;\n    stroke: var(--secondary);\n    stroke-width: 0.5;\n    stroke-dasharray: 400 1200;\n    stroke-dashoffset: 1600;\n    animation: dash 40s linear infinite;\n    filter: drop-shadow(0 0 2px var(--secondary));\n  }\n\n  .tech-line-fast {\n    stroke-width: 0.3;\n    animation-duration: 30s;\n    stroke-opacity: 0.5;\n  }\n\n  .tech-line-slow {\n    stroke-width: 0.8;\n    animation-duration: 60s;\n    stroke-opacity: 0.2;\n  }\n\n  /* Accessibility */\n  @media (prefers-reduced-motion: reduce) {\n    .tech-line, .drift, .glow-pulse {\n      animation: none !important;\n      stroke-dashoffset: 800 !important;\n    }\n  }\n\n  /* Custom UI Styles */\n  .glass-card {\n    background: rgba(255, 255, 255, 0.02);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.05);\n    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);\n  }\n\n  .glass-card:hover {\n    background: rgba(255, 255, 255, 0.05);\n    border-color: rgba(92, 146, 184, 0.4);\n    transform: translateY(-8px);\n    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.5);\n  }\n\n  .btn-primary {\n    background-color: var(--secondary);\n    color: var(--primary);\n    padding: 0.75rem 2rem;\n    border-radius: 9999px;\n    font-weight: 700;\n    transition: all 0.3s ease;\n  }\n\n  .btn-primary:hover {\n    box-shadow: 0 0 20px rgba(92, 146, 184, 0.4);\n    transform: scale(1.05);\n  }\n\n  .btn-ghost {\n    border: 1px solid rgba(255, 255, 255, 0.2);\n    color: white;\n    padding: 0.75rem 2rem;\n    border-radius: 9999px;\n    font-weight: 600;\n    transition: all 0.3s ease;\n  }\n\n  .btn-ghost:hover {\n    background: rgba(255, 255, 255, 0.05);\n    border-color: var(--secondary);\n  }\n</style>\n\n<div class=\"flex flex-col w-full\" data-kid=\"1\">\n  \n  \n  <section class=\"relative h-[850px] flex items-center justify-center bg-[#0a233e] overflow-hidden\" data-kid=\"2\">\n    \n    <div class=\"tech-bg tech-bg-hero z-[1]\" data-kid=\"3\">\n      \n      <div class=\"absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-secondary/10 blur-[150px] rounded-full animate-[glow-pulse_15s_infinite]\" data-kid=\"4\"></div>\n      <div class=\"absolute bottom-1/4 right-1/4 w-[600px] h-[600px] bg-secondary/10 blur-[180px] rounded-full animate-[glow-pulse_25s_infinite_reverse]\" data-kid=\"5\"></div>\n      \n      <svg class=\"w-full h-full opacity-60 animate-[drift-slow_80s_linear_infinite_alternate]\" viewBox=\"0 0 1000 1000\" preserveAspectRatio=\"xMidYMid slice\" data-kid=\"6\">\n        <path class=\"tech-line\" d=\"M -100,200 C 200,400 500,100 1100,300\" data-kid=\"7\"></path>\n        <path class=\"tech-line tech-line-fast\" style=\"animation-delay: -5s\" d=\"M -100,400 C 300,200 600,500 1100,100\" data-kid=\"8\"></path>\n        <path class=\"tech-line tech-line-slow\" style=\"animation-delay: -10s\" d=\"M -100,600 C 400,800 700,400 1100,700\" data-kid=\"9\"></path>\n        <path class=\"tech-line\" style=\"animation-delay: -15s\" d=\"M -100,100 C 100,500 400,200 1100,500\" data-kid=\"10\"></path>\n        <path class=\"tech-line tech-line-fast\" style=\"animation-delay: -2s\" d=\"M 200,-100 C 400,300 100,600 300,1100\" data-kid=\"11\"></path>\n        <path class=\"tech-line tech-line-slow\" style=\"animation-delay: -8s\" d=\"M 500,-100 C 700,400 400,700 600,1100\" data-kid=\"12\"></path>\n        <path class=\"tech-line\" style=\"animation-delay: -25s\" d=\"M -100,800 C 300,900 600,600 1100,900\" data-kid=\"13\"></path>\n        <path class=\"tech-line tech-line-fast\" style=\"animation-delay: -12s\" d=\"M 800,-100 C 900,200 600,500 900,1100\" data-kid=\"14\"></path>\n        <path class=\"tech-line\" style=\"animation-delay: -40s\" d=\"M -200,500 C 300,600 700,400 1200,500\" data-kid=\"15\"></path>\n        <path class=\"tech-line tech-line-fast\" style=\"animation-delay: -32s\" d=\"M 300,-100 L 700,1100\" data-kid=\"16\"></path>\n        <path class=\"tech-line tech-line-slow\" style=\"animation-delay: -45s\" d=\"M 600,-100 L 400,1100\" data-kid=\"17\"></path>\n      </svg>\n    </div>\n\n    \n    <div class=\"relative z-10 max-w-5xl px-6 text-center\" data-kid=\"18\">\n      <div class=\"inline-flex items-center gap-3 px-5 py-2 mb-10 text-[10px] font-bold tracking-[0.25em] uppercase border rounded-full border-secondary/30 bg-secondary/10 text-secondary animate-fade-in backdrop-blur-xl\" data-kid=\"19\">\n        <span class=\"w-1.5 h-1.5 rounded-full bg-secondary animate-pulse\" data-kid=\"20\"></span>\n        Infrastructure de Demain\n      </div>\n      <h1 class=\"mb-8 text-6xl md:text-8xl lg:text-9xl font-serif leading-[1.05] animate-fade-in-up tracking-tight\" data-kid=\"21\">\n        Infrastructure de <em data-kid=\"22\">Demain</em>\n      </h1>\n      <p class=\"mb-12 text-lg md:text-2xl text-white/70 font-sans max-w-3xl mx-auto leading-relaxed animate-fade-in-up\" style=\"animation-delay: 0.2s\" data-kid=\"23\">\n        Architecture réseau de haute performance conçue pour les entreprises visionnaires. Résilience, évolutivité et puissance sans compromis.\n      </p>\n      <div class=\"flex flex-wrap items-center justify-center gap-6 animate-fade-in-up\" style=\"animation-delay: 0.4s\" data-kid=\"24\">\n        <button class=\"btn-primary min-w-[200px] py-4\" data-kid=\"25\">Découvrir l'expertise</button>\n        <button class=\"btn-ghost min-w-[200px] py-4\" data-kid=\"26\">Parlons projet</button>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative py-32 bg-[#0a233e] overflow-hidden border-y border-white/5\" data-kid=\"27\">\n    \n    <div class=\"tech-bg tech-bg-section\" data-kid=\"28\">\n      <svg class=\"w-full h-full opacity-20\" viewBox=\"0 0 1440 400\" preserveAspectRatio=\"xMidYMid slice\" data-kid=\"29\">\n        <path class=\"tech-line\" style=\"animation-duration: 50s;\" d=\"M -200,100 C 100,130 400,70 700,100 S 1300,130 1600,100\" data-kid=\"30\"></path>\n        <path class=\"tech-line tech-line-fast\" style=\"animation-delay: -15s; animation-duration: 40s;\" d=\"M -200,200 C 100,230 400,170 700,200 S 1300,230 1600,200\" data-kid=\"31\"></path>\n        <path class=\"tech-line tech-line-slow\" style=\"animation-delay: -30s; animation-duration: 60s;\" d=\"M -200,300 C 100,330 400,270 700,300 S 1300,330 1600,300\" data-kid=\"32\"></path>\n      </svg>\n    </div>\n\n    <div class=\"relative z-10 max-w-7xl mx-auto px-6\" data-kid=\"33\">\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\" data-kid=\"34\">\n        \n        <div class=\"glass-card p-10 rounded-3xl group relative overflow-hidden\" data-kid=\"35\">\n          <div class=\"w-14 h-14 mb-8 flex items-center justify-center rounded-2xl bg-secondary/10 text-secondary group-hover:bg-secondary group-hover:text-primary transition-all duration-500 shadow-inner\" data-kid=\"36\">\n            <i class=\"ti ti-cpu text-3xl\" data-kid=\"37\"></i>\n          </div>\n          <h3 class=\"text-2xl font-serif mb-5 group-hover:text-secondary transition-colors\" data-kid=\"38\"><em data-kid=\"39\">Calcul</em> Haute Performance</h3>\n          <p class=\"text-white/50 leading-relaxed text-lg\" data-kid=\"40\">\n            Optimisez vos charges de travail critiques avec une puissance de calcul adaptée à vos exigences les plus élevées.\n          </p>\n        </div>\n\n        \n        <div class=\"glass-card p-10 rounded-3xl group relative overflow-hidden\" data-kid=\"41\">\n          <div class=\"w-14 h-14 mb-8 flex items-center justify-center rounded-2xl bg-secondary/10 text-secondary group-hover:bg-secondary group-hover:text-primary transition-all duration-500 shadow-inner\" data-kid=\"42\">\n            <i class=\"ti ti-network text-3xl\" data-kid=\"43\"></i>\n          </div>\n          <h3 class=\"text-2xl font-serif mb-5 group-hover:text-secondary transition-colors\" data-kid=\"44\">Réseau <em data-kid=\"45\">Intelligent</em></h3>\n          <p class=\"text-white/50 leading-relaxed text-lg\" data-kid=\"46\">\n            Une connectivité fluide et redondée pour garantir une disponibilité maximale de vos services à travers le monde.\n          </p>\n        </div>\n\n        \n        <div class=\"glass-card p-10 rounded-3xl group relative overflow-hidden\" data-kid=\"47\">\n          <div class=\"w-14 h-14 mb-8 flex items-center justify-center rounded-2xl bg-secondary/10 text-secondary group-hover:bg-secondary group-hover:text-primary transition-all duration-500 shadow-inner\" data-kid=\"48\">\n            <i class=\"ti ti-shield-check text-3xl\" data-kid=\"49\"></i>\n          </div>\n          <h3 class=\"text-2xl font-serif mb-5 group-hover:text-secondary transition-colors\" data-kid=\"50\">Sécurité <em data-kid=\"51\">End-to-End</em></h3>\n          <p class=\"text-white/50 leading-relaxed text-lg\" data-kid=\"52\">\n            Protection multi-couches de vos données et infrastructures contre les menaces émergentes.\n          </p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative h-[600px] flex items-center justify-center bg-[#0a233e] overflow-hidden\" data-kid=\"53\">\n    \n    <div class=\"tech-bg tech-bg-cta\" data-kid=\"54\">\n      <svg class=\"w-full h-full opacity-40\" viewBox=\"0 0 1000 600\" preserveAspectRatio=\"xMidYMid slice\" data-kid=\"55\">\n        <defs data-kid=\"56\">\n          <radialGradient id=\"cta-glow\" data-kid=\"57\">\n            <stop offset=\"0%\" stop-color=\"#5c92b8\" stop-opacity=\"0.4\" data-kid=\"58\"></stop>\n            <stop offset=\"100%\" stop-color=\"#5c92b8\" stop-opacity=\"0\" data-kid=\"59\"></stop>\n          </radialGradient>\n        </defs>\n        \n        \n        <path class=\"tech-line\" style=\"animation-duration: 20s\" d=\"M 0,0 L 500,300\" data-kid=\"60\"></path>\n        <path class=\"tech-line\" style=\"animation-duration: 20s; animation-delay: -2s\" d=\"M 1000,0 L 500,300\" data-kid=\"61\"></path>\n        <path class=\"tech-line\" style=\"animation-duration: 20s; animation-delay: -4s\" d=\"M 0,600 L 500,300\" data-kid=\"62\"></path>\n        <path class=\"tech-line\" style=\"animation-duration: 20s; animation-delay: -6s\" d=\"M 1000,600 L 500,300\" data-kid=\"63\"></path>\n        <path class=\"tech-line\" style=\"animation-duration: 20s; animation-delay: -8s\" d=\"M 500,0 L 500,300\" data-kid=\"64\"></path>\n        <path class=\"tech-line\" style=\"animation-duration: 20s; animation-delay: -10s\" d=\"M 500,600 L 500,300\" data-kid=\"65\"></path>\n        <path class=\"tech-line\" style=\"animation-duration: 20s; animation-delay: -12s\" d=\"M 0,300 L 500,300\" data-kid=\"66\"></path>\n        <path class=\"tech-line\" style=\"animation-duration: 20s; animation-delay: -14s\" d=\"M 1000,300 L 500,300\" data-kid=\"67\"></path>\n\n        \n        <circle cx=\"500\" cy=\"300\" r=\"150\" fill=\"url(#cta-glow)\" class=\"animate-[glow-pulse_8s_ease-in-out_infinite]\" data-kid=\"68\"></circle>\n      </svg>\n    </div>\n\n    \n    <div class=\"relative z-10 text-center px-6\" data-kid=\"69\">\n      <h2 class=\"text-4xl md:text-6xl font-serif mb-8 max-w-2xl mx-auto leading-[1.2] animate-fade-in-up\" data-kid=\"70\">\n        Prêt à passer à <br data-kid=\"71\"><em data-kid=\"72\">l'échelle</em> ?\n      </h2>\n      <p class=\"text-white/70 font-sans mb-12 max-w-xl mx-auto text-lg animate-fade-in-up\" style=\"animation-delay: 0.2s\" data-kid=\"73\">\n        Rejoignez les entreprises qui transforment leur potentiel en réalité technologique avec Trinexta.\n      </p>\n      <button class=\"btn-primary px-10 py-4 text-lg animate-fade-in-up shadow-lg shadow-secondary/20\" style=\"animation-delay: 0.4s\" data-kid=\"74\">\n        Démarrer un projet\n      </button>\n    </div>\n  </section>\n\n</div>\n\n<script data-kid=\"75\">\n  // Simple scroll fade-in simulation since we can't use complex intersection observers effectively in this environment\n  // We apply immediate entrance animations for visibility\n  document.addEventListener('DOMContentLoaded', () => {\n    // Add any necessary runtime JS here\n  });\n</script>\n",
