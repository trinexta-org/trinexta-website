      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap');\n\n  :root {\n    --primary: #0a233e;\n    --secondary: #5c92b8;\n    --font-serif: 'Playfair Display', serif;\n    --font-sans: 'Geist', sans-serif;\n  }\n\n  /* Core Technical Background Logic */\n  .tech-bg-container {\n    position: relative;\n    width: 100%;\n    background-color: var(--primary);\n    overflow: hidden;\n  }\n\n  /* Component: AnimatedTechnicalBackground */\n  .tech-bg {\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    z-index: 0;\n    overflow: hidden;\n  }\n\n  /* Variants */\n  .tech-bg-hero {\n    mask-image: radial-gradient(circle at center, black 15%, transparent 85%);\n    -webkit-mask-image: radial-gradient(circle at center, black 15%, transparent 85%);\n  }\n\n  .tech-bg-section {\n    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);\n    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);\n  }\n\n  .tech-bg-cta {\n    mask-image: radial-gradient(circle at center, black 10%, transparent 95%);\n    -webkit-mask-image: radial-gradient(circle at center, black 10%, transparent 95%);\n  }\n\n  /* Circuitry Styles */\n  @keyframes circuit-pulse-flow {\n    to { stroke-dashoffset: -1000; }\n  }\n\n  @keyframes tech-drift-slow {\n    0% { transform: scale(1) translate(0, 0); }\n    50% { transform: scale(1.03) translate(0.5%, 0.5%); }\n    100% { transform: scale(1) translate(0, 0); }\n  }\n\n  .circuit-trace {\n    fill: none;\n    stroke-linecap: square;\n    stroke-linejoin: miter;\n  }\n\n  .circuit-base {\n    stroke: var(--secondary);\n    stroke-opacity: 0.08;\n    stroke-width: 1;\n  }\n\n  .circuit-pulse {\n    stroke: var(--secondary);\n    stroke-opacity: 0.25;\n    stroke-width: 1.5;\n    stroke-dasharray: 30 270;\n    animation: circuit-pulse-flow 25s linear infinite;\n  }\n\n  .circuit-pad {\n    fill: var(--secondary);\n    fill-opacity: 0.15;\n  }\n\n  .circuit-pad-active {\n    fill: var(--secondary);\n    fill-opacity: 0.4;\n    filter: blur(1px);\n  }\n\n  .tech-drift {\n    animation: tech-drift-slow 40s ease-in-out infinite;\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    .tech-line, .tech-drift {\n      animation: none !important;\n    }\n    .tech-line {\n      stroke-dashoffset: 300 !important;\n    }\n  }\n\n  /* Mobile Simplification */\n  @media (max-width: 767px) {\n    .tech-bg svg {\n      opacity: 0.5; /* Fade out complexity */\n    }\n    .mobile-hide {\n      display: none;\n    }\n  }\n\n  /* Showcase Helpers */\n  .showcase-wrapper {\n    background-color: var(--primary);\n    color: white;\n    font-family: var(--font-sans);\n  }\n  \n  .showcase-label {\n    font-size: 0.7rem;\n    font-weight: 900;\n    text-transform: uppercase;\n    letter-spacing: 0.25em;\n    color: var(--secondary);\n    margin-bottom: 1rem;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 0.75rem;\n  }\n\n  .showcase-label::before, .showcase-label::after {\n    content: \"\";\n    height: 1px;\n    width: 2rem;\n    background: currentColor;\n    opacity: 0.3;\n  }\n\n  .showcase-title {\n    font-family: var(--font-serif);\n    font-size: clamp(2.5rem, 5vw, 4rem);\n    line-height: 1.1;\n    margin-bottom: 1.5rem;\n    font-weight: 900;\n    text-shadow: 0 4px 12px rgba(0, 0, 0, 0.5);\n  }\n\n  .showcase-title em {\n    font-style: italic;\n  }\n</style>\n\n<div class=\"showcase-wrapper flex flex-col gap-16 p-10 lg:p-20\" data-kid=\"1\">\n  \n  \n  <div class=\"relative flex flex-col items-center justify-center h-[700px] border border-white/5 rounded-3xl overflow-hidden bg-[#0a233e] shadow-2xl\" data-kid=\"2\">\n    \n    <div class=\"tech-bg tech-bg-hero tech-drift\" data-kid=\"3\">\n      <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 1200 800\" preserveAspectRatio=\"xMidYMid slice\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"4\">\n        <defs data-kid=\"5\">\n          <g id=\"circuit-unit\" data-kid=\"6\">\n            <path class=\"circuit-trace\" d=\"M100,100 L250,100 L250,150 L400,150 L400,300\" data-kid=\"7\"></path>\n            <path class=\"circuit-trace\" d=\"M150,200 L150,250 L300,250 L300,400\" data-kid=\"8\"></path>\n            <path class=\"circuit-trace\" d=\"M500,50 L500,200 L650,200 L650,350 L800,350\" data-kid=\"9\"></path>\n            <circle class=\"circuit-pad\" cx=\"100\" cy=\"100\" r=\"3\" data-kid=\"10\"></circle>\n            <circle class=\"circuit-pad\" cx=\"400\" cy=\"300\" r=\"3\" data-kid=\"11\"></circle>\n            <circle class=\"circuit-pad\" cx=\"800\" cy=\"350\" r=\"3\" data-kid=\"12\"></circle>\n          </g>\n        </defs>\n        \n        <g class=\"circuit-base\" data-kid=\"13\">\n          <use href=\"#circuit-unit\" x=\"0\" y=\"0\" data-kid=\"14\"></use>\n          <use href=\"#circuit-unit\" x=\"400\" y=\"200\" data-kid=\"15\"></use>\n          <use href=\"#circuit-unit\" x=\"100\" y=\"450\" data-kid=\"16\"></use>\n          <use href=\"#circuit-unit\" x=\"600\" y=\"-100\" data-kid=\"17\"></use>\n          <use href=\"#circuit-unit\" x=\"800\" y=\"400\" data-kid=\"18\"></use>\n          <use href=\"#circuit-unit\" x=\"-200\" y=\"300\" data-kid=\"19\"></use>\n        </g>\n        \n        <g class=\"circuit-pulse\" data-kid=\"28\">\n          <use href=\"#circuit-unit\" x=\"0\" y=\"0\" style=\"animation-delay: -2s;\" data-kid=\"29\"></use>\n          <use href=\"#circuit-unit\" x=\"400\" y=\"200\" style=\"animation-delay: -5s;\" data-kid=\"30\"></use>\n          <use href=\"#circuit-unit\" x=\"100\" y=\"450\" style=\"animation-delay: -8s;\" data-kid=\"31\"></use>\n          <use href=\"#circuit-unit\" x=\"600\" y=\"-100\" style=\"animation-delay: -12s;\" data-kid=\"32\"></use>\n          <use href=\"#circuit-unit\" x=\"800\" y=\"400\" style=\"animation-delay: -15s;\" data-kid=\"33\"></use>\n        </g>\n      </svg>\n    </div>\n    \n\n    \n    <div class=\"relative z-10 text-center max-w-2xl px-6\" data-kid=\"20\">\n      <span class=\"showcase-label\" data-kid=\"21\">Variant: Hero</span>\n      <h2 class=\"showcase-title\" data-kid=\"22\">Architecture technique de <em data-kid=\"23\">demain</em></h2>\n      <p class=\"text-white/60 text-lg\" data-kid=\"24\">Une immersion visuelle dense pour vos sections de haut de page. Conçu pour captiver et rassurer.</p>\n    </div>\n  </div>\n\n  \n  <div class=\"relative flex items-center h-[400px] border border-white/5 rounded-3xl overflow-hidden bg-[#0a233e]\" data-kid=\"25\">\n    \n    <div class=\"tech-bg tech-bg-section\" data-kid=\"26\">\n      <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 1440 400\" preserveAspectRatio=\"xMidYMid slice\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"27\">\n        <defs data-kid=\"34\">\n          <g id=\"horizontal-trace\" data-kid=\"44\">\n            <path class=\"circuit-trace\" d=\"M0,50 L400,50 L450,100 L1440,100\" data-kid=\"45\"></path>\n            <path class=\"circuit-trace\" d=\"M0,150 L200,150 L250,200 L800,200 L850,150 L1440,150\" data-kid=\"46\"></path>\n            <path class=\"circuit-trace\" d=\"M0,300 L600,300 L650,250 L1440,250\" data-kid=\"47\"></path>\n            <circle class=\"circuit-pad\" cx=\"425\" cy=\"75\" r=\"2.5\" data-kid=\"48\"></circle>\n            <circle class=\"circuit-pad\" cx=\"825\" cy=\"175\" r=\"2.5\" data-kid=\"49\"></circle>\n          </g>\n        </defs>\n        <g class=\"circuit-base\" data-kid=\"50\">\n          <use href=\"#horizontal-trace\" x=\"0\" y=\"0\" data-kid=\"57\"></use>\n          <use href=\"#horizontal-trace\" x=\"0\" y=\"100\" data-kid=\"58\"></use>\n          <use href=\"#horizontal-trace\" x=\"0\" y=\"-50\" data-kid=\"59\"></use>\n        </g>\n        <g class=\"circuit-pulse\" style=\"animation-duration: 18s;\" data-kid=\"60\">\n          <use href=\"#horizontal-trace\" x=\"0\" y=\"0\" style=\"animation-delay: -4s;\" data-kid=\"61\"></use>\n          <use href=\"#horizontal-trace\" x=\"0\" y=\"100\" style=\"animation-delay: -9s;\" data-kid=\"62\"></use>\n        </g>\n      </svg>\n    </div>\n    \n\n    <div class=\"relative z-10 w-full max-w-7xl mx-auto px-10\" data-kid=\"35\">\n      <div class=\"max-w-xl\" data-kid=\"36\">\n        <span class=\"showcase-label\" data-kid=\"37\">Variant: Section</span>\n        <h2 class=\"showcase-title\" data-kid=\"38\">Flux de données <em data-kid=\"39\">optimisés</em></h2>\n        <p class=\"text-white/60 text-lg\" data-kid=\"40\">Un motif horizontal subtil qui accompagne la lecture sans distraire l'utilisateur.</p>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"relative flex flex-col items-center justify-center h-[500px] border border-white/5 rounded-3xl overflow-hidden bg-[#0a233e]\" data-kid=\"41\">\n    \n    <div class=\"tech-bg tech-bg-cta\" data-kid=\"42\">\n      <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 1000 500\" preserveAspectRatio=\"xMidYMid slice\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"43\">\n        <defs data-kid=\"63\">\n          <g id=\"converging-trace\" data-kid=\"64\">\n            \n            <path class=\"circuit-trace\" d=\"M50,50 L200,50 L200,200 L400,200\" data-kid=\"65\"></path>\n            \n            <path class=\"circuit-trace\" d=\"M50,450 L300,450 L300,300 L450,300\" data-kid=\"66\"></path>\n            \n            <path class=\"circuit-trace\" d=\"M950,50 L800,50 L800,150 L600,150\" data-kid=\"67\"></path>\n            \n            <path class=\"circuit-trace\" d=\"M950,450 L700,450 L700,350 L550,350\" data-kid=\"68\"></path>\n            \n            <circle class=\"circuit-pad\" cx=\"400\" cy=\"200\" r=\"4\" data-kid=\"69\"></circle>\n            <circle class=\"circuit-pad\" cx=\"450\" cy=\"300\" r=\"4\" data-kid=\"70\"></circle>\n            <circle class=\"circuit-pad\" cx=\"600\" cy=\"150\" r=\"4\" data-kid=\"71\"></circle>\n            <circle class=\"circuit-pad\" cx=\"550\" cy=\"350\" r=\"4\" data-kid=\"72\"></circle>\n          </g>\n        </defs>\n        <g class=\"circuit-base\" data-kid=\"73\">\n          <use href=\"#converging-trace\" x=\"0\" y=\"0\" data-kid=\"74\"></use>\n          <use href=\"#converging-trace\" x=\"10\" y=\"10\" opacity=\"0.5\" data-kid=\"75\"></use>\n        </g>\n        <g class=\"circuit-pulse\" style=\"animation-duration: 12s;\" data-kid=\"76\">\n          <use href=\"#converging-trace\" x=\"0\" y=\"0\" style=\"animation-delay: -1s;\" data-kid=\"77\"></use>\n          <use href=\"#converging-trace\" x=\"10\" y=\"10\" style=\"animation-delay: -6s;\" data-kid=\"78\"></use>\n        </g>\n      </svg>\n    </div>\n    \n\n    <div class=\"relative z-10 text-center max-w-2xl px-6\" data-kid=\"51\">\n      <span class=\"showcase-label\" data-kid=\"52\">Variant: CTA</span>\n      <h2 class=\"showcase-title\" data-kid=\"53\">Prêt à passer à <em data-kid=\"54\">l'échelle</em>&nbsp;?</h2>\n      <p class=\"text-white/60 text-lg mb-8\" data-kid=\"55\">La convergence de l'expertise et de l'innovation technologique au service de votre croissance.</p>\n      <button class=\"px-10 py-4 font-bold rounded-full hover:scale-105 transition-transform shadow-2xl shadow-secondary/30\" style=\"background-color: var(--secondary); color: var(--primary);\" data-kid=\"56\">\n        Démarrer l'aventure\n      </button>\n    </div>\n  </div>\n\n</div>\n",
